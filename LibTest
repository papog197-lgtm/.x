		Size                  = UDim2.new(1, 0, 1, 0),
		BackgroundTransparency = 1,
		Text                  = "",
		Name                  = genId(5),
		Parent                = row,
	})
	hitbox.MouseButton1Click:Connect(function()
		if self._lib._locked or self._lib._destroyed then return end
		state = not state
		tw(track, { BackgroundColor3 = state and t.ToggleOn or t.ToggleOff }, 0.2)
		tw(knob,  { Position = state and UDim2.new(1, -19, 0.5, -8) or UDim2.new(0, 3, 0.5, -8) }, 0.2)
