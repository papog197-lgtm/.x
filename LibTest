function Library:Notify(text, duration, kind)
	if self._destroyed then return end
	duration = duration or 3
	local t  = self._t
	local accentColor = t.Accent
	if kind == "success" then accentColor = t.Success
	elseif kind == "warn"    then accentColor = t.Warning
	elseif kind == "warning" then accentColor = t.Warning
	elseif kind == "error"   then accentColor = t.Error end

	self._notifyCount = self._notifyCount + 1
	local order = self._notifyCount

	local card = new("Frame", {
		Name             = genId(6),
		Size             = UDim2.new(1, 0, 0, 50),
		BackgroundColor3 = t.NotifyBg,
		BackgroundTransparency = 0.08,
		BorderSizePixel  = 0,
		LayoutOrder      = order,
		ZIndex           = 52,
		Parent           = self._notifyHolder,
	})
	new("UICorner",  { CornerRadius = UDim.new(0, 10), Parent = card })
	new("UIStroke",  { Color = accentColor, Thickness = 1, Transparency = 0.35, Parent = card })

	local bar = new("Frame", {
		Name             = genId(4),
		Size             = UDim2.new(0, 3, 0.65, 0),
		Position         = UDim2.new(0, 0, 0.175, 0),
		BackgroundColor3 = accentColor,
		BorderSizePixel  = 0,
		ZIndex           = 53,
		Parent           = card,
	})
	new("UICorner", { CornerRadius = UDim.new(0, 2), Parent = bar })

	new("TextLabel", {
		Name                   = genId(5),
		Size                   = UDim2.new(1, -22, 1, 0),
		Position               = UDim2.new(0, 14, 0, 0),
		BackgroundTransparency = 1,
		Font                   = Enum.Font.Gotham,
		Text                   = text or "",
		TextColor3             = t.Text,
		TextSize               = 13,
		TextWrapped            = true,
		TextXAlignment         = Enum.TextXAlignment.Left,
		ZIndex                 = 53,
		Parent                 = card,
	})

	-- Slide in da destra
	card.Position = UDim2.new(1, 20, 0, 0)
	tw(card, { Position = UDim2.new(0, 0, 0, 0) }, 0.32, Enum.EasingStyle.Back)

	task.delay(duration, function()
		if not card or not card.Parent then return end
		tw(card, { BackgroundTransparency = 1, Position = UDim2.new(1, 20, 0, 0) }, 0.28).Completed:Connect(function()
			pcall(function() card:Destroy() end)
		end)
	end)
end

function Library:Lock()
	self._locked = true
	if self._main then
		local existing = self._main:FindFirstChild("_lock_overlay_")
		if not existing then
			local ov = new("Frame", {
				Name                   = "_lock_overlay_",
				Size                   = UDim2.new(1, 0, 1, 0),
				BackgroundColor3       = Color3.new(0, 0, 0),
