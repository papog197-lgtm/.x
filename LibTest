		TextSize=11,
		TextXAlignment=Enum.TextXAlignment.Left,
		TextTruncate=Enum.TextTruncate.AtEnd,
		LayoutOrder=#self._tabOrder+1,
		ZIndex=24,
		Parent=self._tabBar,
	})
	new("UICorner",{CornerRadius=UDim.new(0,7),Parent=tabBtn})
	new("UIPadding",{PaddingLeft=UDim.new(0,8),Parent=tabBtn})

	local indicator=new("Frame",{
		Name=genId(4),Size=UDim2.new(0,3,0.55,0),Position=UDim2.new(0,0,0.225,0),
		BackgroundColor3=t.Accent,BackgroundTransparency=1,
		BorderSizePixel=0,ZIndex=25,Parent=tabBtn,
	})
	new("UICorner",{CornerRadius=UDim.new(0,2),Parent=indicator})

	local page=new("ScrollingFrame",{
		Name=tabId.."_p",
		Size=UDim2.new(1,0,1,0),
		BackgroundTransparency=1,
		BorderSizePixel=0,
		ScrollBarThickness=3,
		ScrollBarImageColor3=t.Scrollbar,
		ScrollBarImageTransparency=0.35,
		AutomaticCanvasSize=Enum.AutomaticSize.Y,
		CanvasSize=UDim2.new(0,0,0,0),
		Visible=false,
		ZIndex=23,
		Parent=self._contentArea,
	})
	new("UIPadding",{PaddingTop=UDim.new(0,10),PaddingBottom=UDim.new(0,10),PaddingLeft=UDim.new(0,10),PaddingRight=UDim.new(0,14),Parent=page})
	new("UIListLayout",{SortOrder=Enum.SortOrder.LayoutOrder,Padding=UDim.new(0,6),Parent=page})

	local data={id=tabId,name=name,button=tabBtn,page=page,indicator=indicator,_lib=self,_order=#self._tabOrder+1}
	setmetatable(data,TabMethods)
	self._tabs[tabId]=data
	table.insert(self._tabOrder,tabId)

	tabBtn.MouseEnter:Connect(function()
		if self._activeTab~=tabId then tw(tabBtn,{BackgroundColor3=t.TabHover,BackgroundTransparency=0,TextColor3=t.Text},0.12) end
	end)
	tabBtn.MouseLeave:Connect(function()
		if self._activeTab~=tabId then tw(tabBtn,{BackgroundColor3=t.TabInactive,BackgroundTransparency=0.2,TextColor3=t.TextSub},0.12) end
	end)
	tabBtn.MouseButton1Click:Connect(function() self:_selectTab(tabId) end)

	if #self._tabOrder==1 then self:_selectTab(tabId) end
	return data
end

function Library:_selectTab(tabId)
	local t=self._t
	for id,tab in pairs(self._tabs) do
		tab.page.Visible=false
		tw(tab.button,{BackgroundColor3=t.TabInactive,BackgroundTransparency=0.2,TextColor3=t.TextSub},0.12)
		tw(tab.indicator,{BackgroundTransparency=1},0.12)
	end
	local sel=self._tabs[tabId]
	if sel then
		self._activeTab=tabId; sel.page.Visible=true
		tw(sel.button,{BackgroundColor3=t.TabActive,BackgroundTransparency=0,TextColor3=t.Text},0.18)
		tw(sel.indicator,{BackgroundTransparency=0},0.18)
	end
end

function Library:Notify(text, duration, kind)
	if self._destroyed then return end
	duration=duration or 3
	local t=self._t
	local accentColor=t.Accent
	if kind=="success" then accentColor=t.Success
	elseif kind=="warn" or kind=="warning" then accentColor=t.Warning
	elseif kind=="error" then accentColor=t.Error end
	self._notifyCount=self._notifyCount+1
	local order=self._notifyCount
	local card=new("Frame",{Name=genId(6),Size=UDim2.new(1,0,0,50),BackgroundColor3=t.NotifyBg,BackgroundTransparency=0.08,BorderSizePixel=0,LayoutOrder=order,ZIndex=52,Parent=self._notifyHolder})
	new("UICorner",{CornerRadius=UDim.new(0,10),Parent=card})
	new("UIStroke",{Color=accentColor,Thickness=1,Transparency=0.35,Parent=card})
	new("Frame",{Name=genId(4),Size=UDim2.new(0,3,0.65,0),Position=UDim2.new(0,0,0.175,0),BackgroundColor3=accentColor,BorderSizePixel=0,ZIndex=53,Parent=card})
	new("TextLabel",{Name=genId(5),Size=UDim2.new(1,-22,1,0),Position=UDim2.new(0,14,0,0),BackgroundTransparency=1,Font=Enum.Font.Gotham,Text=text or "",TextColor3=t.Text,TextSize=13,TextWrapped=true,TextXAlignment=Enum.TextXAlignment.Left,ZIndex=53,Parent=card})
	card.Position=UDim2.new(1,20,0,0)
	tw(card,{Position=UDim2.new(0,0,0,0)},0.32,Enum.EasingStyle.Back)
	task.delay(duration,function()
		if not card or not card.Parent then return end
		tw(card,{BackgroundTransparency=1,Position=UDim2.new(1,20,0,0)},0.28).Completed:Connect(function() pcall(function() card:Destroy() end) end)
	end)
end

function Library:Lock()
	self._locked=true
	if self._main then
		if not self._main:FindFirstChild("_lock_overlay_") then
			local ov=new("Frame",{Name="_lock_overlay_",Size=UDim2.new(1,0,1,0),BackgroundColor3=Color3.new(0,0,0),BackgroundTransparency=0.55,BorderSizePixel=0,ZIndex=99,Parent=self._main})
			new("TextLabel",{Size=UDim2.new(1,0,0,40),Position=UDim2.new(0,0,0.5,-20),BackgroundTransparency=1,Font=Enum.Font.GothamBold,Text="🔒  Locked",TextColor3=self._t.TextSub,TextSize=16,ZIndex=100,Parent=ov})
		end
	end
end

function Library:Unlock()
	self._locked=false
	if self._main then local ov=self._main:FindFirstChild("_lock_overlay_"); if ov then ov:Destroy() end end
end

function Library:SetAccent(color)
	if not color then return end
	local t=self._t
	t.Accent=color; t.AccentGlow=color; t.ToggleOn=color; t.SliderFill=color; t.TabActive=color
	t.AccentDark=Color3.new(color.R*0.52,color.G*0.52,color.B*0.52)
	if self._activeTab then
		local sel=self._tabs[self._activeTab]
		if sel then tw(sel.button,{BackgroundColor3=color},0.2); tw(sel.indicator,{BackgroundColor3=color},0.2) end
	end
end

function Library:Destroy()
	if self._destroyed then return end
	self._destroyed=true
	local m=self._main; local s=self._shadow
	if m then
		tw(m,{BackgroundTransparency=1},0.3,Enum.EasingStyle.Quart)
		tw(s,{BackgroundTransparency=1},0.3).Completed:Connect(function() pcall(function() if self._sg then self._sg:Destroy() end end) end)
	else
		pcall(function() if self._sg then self._sg:Destroy() end end)
	end
	for _,c in ipairs(self._conn) do pcall(function() c:Disconnect() end) end
	table.clear(self._tabs); table.clear(self._conn)
end

return Library
