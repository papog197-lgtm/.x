		open = not open
		panel.Visible = open
	end)
	return {
		GetValue = function() return chosen end,
		SetOptions = function(_, newOpts)
			for _, c in ipairs(panel:GetChildren()) do
				if c:IsA("TextButton") then c:Destroy() end
			end
		end,
	}
