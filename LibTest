function Library:_selectTab(tabId)
	local t = self._t
	for id, tab in pairs(self._tabs) do
		tab.page.Visible = false
		tw(tab.button,    { BackgroundColor3 = t.TabInactive, TextColor3 = t.TextMuted, BackgroundTransparency = 0.3 }, 0.15)
		tw(tab.indicator, { BackgroundTransparency = 1 }, 0.15)
	end
	local sel = self._tabs[tabId]
	if sel then
		self._activeTab = tabId
		sel.page.Visible = true
		sel.page.CanvasPosition = Vector2.new(0, 0)
		tw(sel.button,    { BackgroundColor3 = t.TabActive, TextColor3 = t.Text, BackgroundTransparency = 0 }, 0.2)
		tw(sel.indicator, { BackgroundTransparency = 0 }, 0.2)
	end
end

function Library:Notify(text, duration, kind)
	if self._destroyed then return end
	duration = duration or 3
	kind     = kind or "info"
	local t  = self._t

	local accentColor = t.Accent
	if kind == "success" then accentColor = t.Success
	elseif kind == "warn" then accentColor = t.Warning
	elseif kind == "error" then accentColor = t.Error end

	self._notifyCount = self._notifyCount + 1
	local order = self._notifyCount

	local card = new("Frame", {
		Name             = genId(6),
		Size             = UDim2.new(1, 0, 0, 48),
		BackgroundColor3 = t.NotifyBg,
		BackgroundTransparency = 0.1,
		BorderSizePixel  = 0,
		LayoutOrder      = order,
		ZIndex           = 52,
		Parent           = self._notifyAnchor,
	})
	new("UICorner",  { CornerRadius = UDim.new(0, 10), Parent = card })
	new("UIStroke",  { Color = accentColor, Thickness = 1, Transparency = 0.4, Parent = card })

	local leftBar = new("Frame", {
		Name             = genId(4),
		Size             = UDim2.new(0, 3, 0.7, 0),
		Position         = UDim2.new(0, 0, 0.15, 0),
		BackgroundColor3 = accentColor,
		BorderSizePixel  = 0,
		ZIndex           = 53,
		Parent           = card,
	})
	new("UICorner", { CornerRadius = UDim.new(0, 2), Parent = leftBar })

	new("TextLabel", {
		Name                  = genId(5),
		Size                  = UDim2.new(1, -20, 1, 0),
		Position              = UDim2.new(0, 14, 0, 0),
		BackgroundTransparency = 1,
		Font                  = Enum.Font.Gotham,
		Text                  = text or "",
		TextColor3            = t.Text,
		TextSize              = 13,
		TextWrapped           = true,
		TextXAlignment        = Enum.TextXAlignment.Left,
		ZIndex                = 53,
		Parent                = card,
	})

	card.Position = UDim2.new(1, 10, 0, 0)
	tw(card, { Position = UDim2.new(0, 0, 0, 0) }, 0.35, Enum.EasingStyle.Back)

	task.delay(duration, function()
		if not card or not card.Parent then return end
		local t2 = tw(card, { BackgroundTransparency = 1, Position = UDim2.new(1, 10, 0, 0) }, 0.3)
		t2.Completed:Connect(function()
			pcall(function() card:Destroy() end)
		end)
	end)
end

function Library:Lock()
	self._locked = true
	if self._main then
		new("Frame", {
			Name                  = "_lock_" .. self._id,
			Size                  = UDim2.new(1, 0, 1, 0),
			BackgroundColor3      = Color3.fromRGB(0, 0, 0),
			BackgroundTransparency = 0.6,
			BorderSizePixel       = 0,
			ZIndex                = 99,
			Parent                = self._main,
		})
	end
end

function Library:Unlock()
	self._locked = false
	if self._main then
		local overlay = self._main:FindFirstChild("_lock_" .. self._id)
		if overlay then overlay:Destroy() end
	end
end

function Library:SetAccent(color)
	if not color then return end
	local t = self._t
	t.Accent     = color
	t.AccentGlow = color
	t.ToggleOn   = color
	t.SliderFill = color
	t.TabActive  = color
	if self._activeTab then
		local sel = self._tabs[self._activeTab]
		if sel then
			sel.button.BackgroundColor3 = color
			sel.indicator.BackgroundColor3 = color
		end
	end
end

function Library:Destroy()
	if self._destroyed then return end
	self._destroyed = true
	local m = self._main
	local s = self._shadow
	if m and s then
		tw(m, { BackgroundTransparency = 1, Position = UDim2.new(0.5, -251, 0.5, -166) }, 0.35, Enum.EasingStyle.Quart)
		local t2 = tw(s, { BackgroundTransparency = 1 }, 0.35)
		t2.Completed:Connect(function()
			pcall(function() if self._sg then self._sg:Destroy() end end)
		end)
	else
		pcall(function() if self._sg then self._sg:Destroy() end end)
	end
	for _, c in ipairs(self._conn) do pcall(function() c:Disconnect() end) end
	table.clear(self._tabs)
	table.clear(self._conn)
end

return Library
