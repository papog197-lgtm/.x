local function showLoading(sg, t, version, onDone)
	local screen = vp()

	-- Overlay scuro semitrasparente
	local overlay = new("Frame", {
		Name                   = genId(6),
		Size                   = UDim2.new(1, 0, 1, 0),
		BackgroundColor3       = Color3.fromRGB(0, 0, 0),
		BackgroundTransparency = 0.45,
		BorderSizePixel        = 0,
		ZIndex                 = 200,
		Parent                 = sg,
	})

	-- Card circolare centrata (120x120)
	local card = new("Frame", {
		Name             = genId(6),
		Size             = UDim2.new(0, 120, 0, 120),
		Position         = UDim2.new(0.5, -60, 0.5, -60),
		BackgroundColor3 = t.BgSec,
		BorderSizePixel  = 0,
		ZIndex           = 202,
		Parent           = overlay,
	})
	new("UICorner", { CornerRadius = UDim.new(1, 0), Parent = card })
	new("UIStroke",  { Color = t.Accent, Thickness = 2.5, Transparency = 0.15, Parent = card })

	-- Anello spinner (orbita)
	local orbit = new("Frame", {
		Name             = genId(5),
		Size             = UDim2.new(0, 100, 0, 100),
		Position         = UDim2.new(0.5, -50, 0.5, -50),
		BackgroundTransparency = 1,
		BorderSizePixel  = 0,
		ZIndex           = 203,
		Parent           = overlay,
	})

	-- Pallino che orbita
	local dot = new("Frame", {
		Name             = genId(4),
		Size             = UDim2.new(0, 10, 0, 10),
		Position         = UDim2.new(0.5, -5, 0, -5),
		BackgroundColor3 = t.AccentGlow,
		BorderSizePixel  = 0,
		ZIndex           = 204,
		Parent           = orbit,
	})
	new("UICorner", { CornerRadius = UDim.new(1, 0), Parent = dot })

	-- Nome "KyUI" al centro
	local nameLbl = new("TextLabel", {
		Name                   = genId(5),
		Size                   = UDim2.new(0, 120, 0, 24),
		Position               = UDim2.new(0.5, -60, 0.5, -22),
		BackgroundTransparency = 1,
		Font                   = Enum.Font.GothamBold,
		Text                   = "KyUI",
		TextColor3             = t.Accent,
		TextSize               = 16,
		TextTransparency       = 1,
		ZIndex                 = 205,
		Parent                 = overlay,
	})

	-- Versione (solo se fornita)
	local verLbl = nil
	if version and version ~= "" then
		verLbl = new("TextLabel", {
			Name                   = genId(5),
			Size                   = UDim2.new(0, 120, 0, 16),
			Position               = UDim2.new(0.5, -60, 0.5, 6),
			BackgroundTransparency = 1,
			Font                   = Enum.Font.Gotham,
			Text                   = version,
			TextColor3             = t.TextMuted,
			TextSize               = 11,
			TextTransparency       = 1,
			ZIndex                 = 205,
			Parent                 = overlay,
		})
	end

	-- Animazione rotazione pallino
	local angle = 0
	local spinConn
	spinConn = RunService.Heartbeat:Connect(function(dt)
		if not orbit or not orbit.Parent then
			pcall(function() spinConn:Disconnect() end)
			return
		end
		angle = angle + dt * 300
		local rad = math.rad(angle)
		local r   = 44
		local nx  = 50 + math.cos(rad) * r - 5
		local ny  = 50 + math.sin(rad) * r - 5
		dot.Position = UDim2.new(0, nx, 0, ny)
	end)

	-- Fade in
	tw(nameLbl, { TextTransparency = 0 }, 0.4)
	if verLbl then tw(verLbl, { TextTransparency = 0 }, 0.5) end

	task.delay(2.2, function()
		pcall(function() spinConn:Disconnect() end)
		tw(overlay, { BackgroundTransparency = 1 }, 0.4)
		tw(card,    { BackgroundTransparency = 1 }, 0.3)
		tw(nameLbl, { TextTransparency = 1 }, 0.25)
		if verLbl then tw(verLbl, { TextTransparency = 1 }, 0.25) end
		task.delay(0.45, function()
			pcall(function() overlay:Destroy() end)
			if onDone then onDone() end
		end)
	end)
end

