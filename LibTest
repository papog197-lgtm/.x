		_order    = #self._tabOrder + 1,
	}
	setmetatable(tabData, TabMethods)

	self._tabs[tabId] = tabData
	table.insert(self._tabOrder, tabId)

	tabBtn.MouseEnter:Connect(function()
		if self._activeTab ~= tabId then
			tw(tabBtn, { BackgroundColor3 = t.TabHover, TextColor3 = t.TextSub, BackgroundTransparency = 0 }, 0.15)
