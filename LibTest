local Library = {}
Library.__index = Library

function Library:Init(cfg)
	if not cfg then return nil end
	if type(cfg.Key) ~= "string" or #cfg.Key < 6 then return nil end
	for _, sg in ipairs(CoreGui:GetChildren()) do
		if sg:IsA("ScreenGui") and sg:FindFirstChild(KYUI_TAG) then sg:Destroy(); task.wait(0.06) end
	end
	local self      = setmetatable({}, Library)
	self._id        = genId(16)
	self._mainId    = genId(10)
	self._cfg       = cfg
	self._tabs      = {}
	self._tabOrder  = {}
	self._activeTab = nil
	self._conn      = {}
	self._locked    = false
	self._destroyed = false
	local t = {}
	for k, v in pairs(DEFAULT) do t[k] = v end
	if cfg.AccentColor then
		t.Accent=cfg.AccentColor; t.AccentGlow=cfg.AccentColor; t.ToggleOn=cfg.AccentColor
		t.SliderFill=cfg.AccentColor; t.TabActive=cfg.AccentColor
		t.AccentDark=Color3.new(cfg.AccentColor.R*0.52,cfg.AccentColor.G*0.52,cfg.AccentColor.B*0.52)
	end
	if cfg.BackgroundColor then t.Bg=cfg.BackgroundColor end
	if cfg.TextColor then t.Text=cfg.TextColor end
	self._t       = t
	self._alpha   = clamp(cfg.Transparency or 0.05,0,0.45)
	self._title   = cfg.Title    or "KyUI"
	self._sub     = cfg.Subtitle or ""
	self._version = cfg.Version  or (cfg.Subtitle and cfg.Subtitle~="" and cfg.Subtitle) or ""
	self._ready   = false
	self._minimized = false
	self:_buildGUI()
	showLoading(self._sg, t, self._version, function()
		if self._destroyed then return end
		self._ready=true; self._main.Visible=true
		self:_setupDrag(); self:_setupGlow(); self:_startIntegrity(); self:_animIn()
		task.wait(); task.wait()
		if self._activeTab then
			local act=self._activeTab; self._activeTab=nil; self:_selectTab(act)
		end
	end)
	task.delay(6, function()
		if not self._ready and not self._destroyed then
			self._ready=true; self._main.Visible=true
			self:_setupDrag(); self:_setupGlow(); self:_startIntegrity(); self:_animIn()
		end
	end)
	return self
end

