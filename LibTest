function TabMethods:Toggle(text, default, callback)
	local t     = self._lib._t
	local row   = self:_row(38)
	local state = default == true
	new("TextLabel", {
		Size                   = UDim2.new(1, -64, 1, 0),
		Position               = UDim2.new(0, 12, 0, 0),
		BackgroundTransparency = 1,
		Font                   = Enum.Font.Gotham,
		Text                   = text or "Toggle",
		TextColor3             = t.Text,
		TextSize               = 13,
		TextXAlignment         = Enum.TextXAlignment.Left,
		Name                   = genId(5),
		Parent                 = row,
	})
	local track = new("Frame", {
		Size             = UDim2.new(0, 44, 0, 22),
		Position         = UDim2.new(1, -54, 0.5, -11),
		BackgroundColor3 = state and t.ToggleOn or t.ToggleOff,
		BorderSizePixel  = 0,
		Name             = genId(5),
		Parent           = row,
	})
	new("UICorner", { CornerRadius = UDim.new(1, 0), Parent = track })
	new("UIStroke",  { Color = t.Border, Thickness = 1, Transparency = 0.25, Parent = track })
	local knob = new("Frame", {
		Size             = UDim2.new(0, 16, 0, 16),
		Position         = state and UDim2.new(1, -19, 0.5, -8) or UDim2.new(0, 3, 0.5, -8),
		BackgroundColor3 = Color3.new(1, 1, 1),
		BorderSizePixel  = 0,
		Name             = genId(5),
		Parent           = track,
	})
	new("UICorner", { CornerRadius = UDim.new(1, 0), Parent = knob })
	local hitbox = new("TextButton", {
		Size                   = UDim2.new(1, 0, 1, 0),
		BackgroundTransparency = 1,
		Text                   = "",
		Name                   = genId(5),
		Parent                 = row,
	})
	hitbox.MouseEnter:Connect(function()
		tw(row, { BackgroundTransparency = 0, BackgroundColor3 = t.TabHover }, 0.10)
	end)
	hitbox.MouseLeave:Connect(function()
		tw(row, { BackgroundTransparency = 0.2, BackgroundColor3 = t.BgSec }, 0.10)
	end)
	hitbox.MouseButton1Click:Connect(function()
		if self._lib._locked or self._lib._destroyed then return end
		state = not state
		tw(track, { BackgroundColor3 = state and t.ToggleOn or t.ToggleOff }, 0.16)
		tw(knob,  { Position = state and UDim2.new(1,-19,0.5,-8) or UDim2.new(0,3,0.5,-8) }, 0.16, Enum.EasingStyle.Back)
		if callback then
			local s, e = pcall(callback, state)
			if not s then warn("[KyUI] Toggle: " .. tostring(e)) end
		end
	end)
	return {
		SetValue = function(_, v)
			state = v == true
			tw(track, { BackgroundColor3 = state and t.ToggleOn or t.ToggleOff }, 0.16)
			tw(knob,  { Position = state and UDim2.new(1,-19,0.5,-8) or UDim2.new(0,3,0.5,-8) }, 0.16, Enum.EasingStyle.Back)
		end,
		GetValue = function() return state end,
	}
end

function TabMethods:Slider(text, min, max, default, callback)
	local t   = self._lib._t
	-- FIX: altezza aumentata per evitare clipping
	local row = self:_row(58)
	local val = clamp(default or min, min, max)

	new("TextLabel", {
		Size                   = UDim2.new(0.65, 0, 0, 22),
		Position               = UDim2.new(0, 12, 0, 6),
		BackgroundTransparency = 1,
		Font                   = Enum.Font.Gotham,
		Text                   = text or "Slider",
		TextColor3             = t.Text,
		TextSize               = 13,
		TextXAlignment         = Enum.TextXAlignment.Left,
		Name                   = genId(5),
		Parent                 = row,
	})
	local valLbl = new("TextLabel", {
		Size                   = UDim2.new(0.3, 0, 0, 22),
		Position               = UDim2.new(0.68, 0, 0, 6),
		BackgroundTransparency = 1,
		Font                   = Enum.Font.GothamBold,
		Text                   = tostring(math.floor(val)),
		TextColor3             = t.Accent,
		TextSize               = 13,
		TextXAlignment         = Enum.TextXAlignment.Right,
		Name                   = genId(5),
		Parent                 = row,
	})
	local track = new("Frame", {
		Size             = UDim2.new(1, -24, 0, 6),
		Position         = UDim2.new(0, 12, 0, 36),
		BackgroundColor3 = t.SliderBg,
		BorderSizePixel  = 0,
		Name             = genId(5),
		Parent           = row,
	})
	new("UICorner", { CornerRadius = UDim.new(1, 0), Parent = track })
	local pct0 = (val - min) / (max - min)
	local fill = new("Frame", {
		Size             = UDim2.new(pct0, 0, 1, 0),
		BackgroundColor3 = t.SliderFill,
		BorderSizePixel  = 0,
		Name             = genId(5),
		Parent           = track,
	})
	new("UICorner", { CornerRadius = UDim.new(1, 0), Parent = fill })
	new("UIGradient", {
		Color = ColorSequence.new({
			ColorSequenceKeypoint.new(0, t.AccentGlow),
			ColorSequenceKeypoint.new(1, t.Accent),
		}),
		Parent = fill,
	})
	local thumb = new("Frame", {
		Size             = UDim2.new(0, 14, 0, 14),
		Position         = UDim2.new(pct0, -7, 0.5, -7),
		BackgroundColor3 = Color3.new(1, 1, 1),
		BorderSizePixel  = 0,
		ZIndex           = 3,
		Name             = genId(5),
		Parent           = track,
	})
	new("UICorner", { CornerRadius = UDim.new(1, 0), Parent = thumb })
	new("UIStroke",  { Color = t.Accent, Thickness = 2, Parent = thumb })
	local dragging = false
	local hitbox = new("TextButton", {
		Size                   = UDim2.new(1, 0, 0, 36),
		Position               = UDim2.new(0, 0, 0, -15),
		BackgroundTransparency = 1,
		Text                   = "",
		ZIndex                 = 4,
		Name                   = genId(5),
		Parent                 = track,
	})
	local function setSlider(ix)
		local pct = clamp((ix - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
		val = math.floor(min + (max - min) * pct)
		valLbl.Text    = tostring(val)
		fill.Size      = UDim2.new(pct, 0, 1, 0)
		thumb.Position = UDim2.new(pct, -7, 0.5, -7)
		if callback then
			local s, e = pcall(callback, val)
			if not s then warn("[KyUI] Slider: " .. tostring(e)) end
		end
	end
	hitbox.MouseButton1Down:Connect(function(x)
		if self._lib._locked or self._lib._destroyed then return end
		dragging = true
		setSlider(x)
	end)
	local mc = UserInputService.InputChanged:Connect(function(inp)
		if dragging and inp.UserInputType == Enum.UserInputType.MouseMovement then
			setSlider(inp.Position.X)
		end
	end)
	local uc = UserInputService.InputEnded:Connect(function(inp)
		if inp.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
	end)
	table.insert(self._lib._conn, mc)
	table.insert(self._lib._conn, uc)
	return {
		SetValue = function(_, v)
			val = clamp(v, min, max)
			local pct = (val - min) / (max - min)
			valLbl.Text    = tostring(math.floor(val))
			fill.Size      = UDim2.new(pct, 0, 1, 0)
			thumb.Position = UDim2.new(pct, -7, 0.5, -7)
		end,
		GetValue = function() return val end,
	}
end

