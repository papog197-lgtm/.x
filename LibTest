function Library:Unlock()
	self._locked = false
	if self._main then
		local ov = self._main:FindFirstChild("_lock_overlay_")
		if ov then ov:Destroy() end
	end
end

function Library:SetAccent(color)
	if not color then return end
	local t = self._t
	t.Accent     = color
	t.AccentGlow = color
	t.ToggleOn   = color
	t.SliderFill = color
	t.TabActive  = color
	t.AccentDark = Color3.new(color.R * 0.52, color.G * 0.52, color.B * 0.52)
	if self._activeTab then
		local sel = self._tabs[self._activeTab]
		if sel then
			tw(sel.button,    { BackgroundColor3 = color }, 0.2)
			tw(sel.indicator, { BackgroundColor3 = color }, 0.2)
		end
	end
end

function Library:Destroy()
	if self._destroyed then return end
	self._destroyed = true
	local m = self._main
	local s = self._shadow
	if m then
		tw(m, { BackgroundTransparency = 1 }, 0.3, Enum.EasingStyle.Quart)
		local t2 = tw(s, { BackgroundTransparency = 1 }, 0.3)
		t2.Completed:Connect(function()
			pcall(function() if self._sg then self._sg:Destroy() end end)
		end)
	else
		pcall(function() if self._sg then self._sg:Destroy() end end)
	end
	for _, c in ipairs(self._conn) do pcall(function() c:Disconnect() end) end
	table.clear(self._tabs)
	table.clear(self._conn)
end

return Library
