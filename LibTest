	new("UICorner", { CornerRadius=UDim.new(1,0), Parent=fill })
	new("UIGradient", { Color=ColorSequence.new({ColorSequenceKeypoint.new(0,t.AccentGlow),ColorSequenceKeypoint.new(1,t.Accent)}), Parent=fill })
	local thumb = new("Frame", { Size=UDim2.new(0,14,0,14), Position=UDim2.new(pct0,-7,0.5,-7), BackgroundColor3=Color3.new(1,1,1), BorderSizePixel=0, ZIndex=3, Name=genId(5), Parent=track })
	new("UICorner", { CornerRadius=UDim.new(1,0), Parent=thumb })
	new("UIStroke",  { Color=t.Accent, Thickness=2, Parent=thumb })
	local dragging = false
	local hitbox = new("TextButton", { Size=UDim2.new(1,0,0,36), Position=UDim2.new(0,0,0,-15), BackgroundTransparency=1, Text="", ZIndex=4, Name=genId(5), Parent=track })
	local function setSlider(ix)
		local pct = clamp((ix-track.AbsolutePosition.X)/track.AbsoluteSize.X,0,1)
		val = math.floor(min+(max-min)*pct)
		valLbl.Text=tostring(val); fill.Size=UDim2.new(pct,0,1,0); thumb.Position=UDim2.new(pct,-7,0.5,-7)
		if callback then local s,e=pcall(callback,val); if not s then warn("[KyUI] Slider: "..tostring(e)) end end
	end
	hitbox.MouseButton1Down:Connect(function(x) if self._lib._locked or self._lib._destroyed then return end dragging=true setSlider(x) end)
	local mc=UserInputService.InputChanged:Connect(function(inp) if dragging and inp.UserInputType==Enum.UserInputType.MouseMovement then setSlider(inp.Position.X) end end)
	local uc=UserInputService.InputEnded:Connect(function(inp) if inp.UserInputType==Enum.UserInputType.MouseButton1 then dragging=false end end)
	table.insert(self._lib._conn,mc); table.insert(self._lib._conn,uc)
	return {
		SetValue=function(_,v) val=clamp(v,min,max); local pct=(val-min)/(max-min); valLbl.Text=tostring(math.floor(val)); fill.Size=UDim2.new(pct,0,1,0); thumb.Position=UDim2.new(pct,-7,0.5,-7) end,
		GetValue=function() return val end,
