function Library:_setupDrag()
	local main    = self._main
	local topBar  = self._topBar
	local active  = false
	local startInput = Vector2.new(0, 0)
	local startPos   = Vector2.new(self._targX, self._targY)

	local c1 = topBar.InputBegan:Connect(function(inp)
		if inp.UserInputType ~= Enum.UserInputType.MouseButton1 and
		   inp.UserInputType ~= Enum.UserInputType.Touch then return end
		active     = true
		startInput = Vector2.new(inp.Position.X, inp.Position.Y)
		startPos   = Vector2.new(self._targX, self._targY)
	end)

	local c2 = UserInputService.InputChanged:Connect(function(inp)
		if not active then return end
		if inp.UserInputType ~= Enum.UserInputType.MouseMovement and
		   inp.UserInputType ~= Enum.UserInputType.Touch then return end
		local dx = inp.Position.X - startInput.X
		local dy = inp.Position.Y - startInput.Y
		self._targX = startPos.X + dx
		self._targY = startPos.Y + dy
		self._dragging = true
	end)

	local c3 = UserInputService.InputEnded:Connect(function(inp)
		if inp.UserInputType == Enum.UserInputType.MouseButton1 or
		   inp.UserInputType == Enum.UserInputType.Touch then
			active = false
			self._dragging = false
		end
	end)

	-- FIX LAG: RenderStepped gira solo quando si sta trascinando
	-- (usando flag _dragging per evitare lavoro inutile ogni frame)
	local c4 = RunService.RenderStepped:Connect(function(dt)
		if self._destroyed then return end
		local diffX = self._targX - self._lerpX
		local diffY = self._targY - self._lerpY
		if math.abs(diffX) < 0.3 and math.abs(diffY) < 0.3 then
			-- Snap e poi stop
			if diffX ~= 0 or diffY ~= 0 then
				self._lerpX = self._targX
				self._lerpY = self._targY
				local lx = math.floor(self._lerpX)
				local ly = math.floor(self._lerpY)
				main.Position         = UDim2.new(0, lx, 0, ly)
				self._shadow.Position = UDim2.new(0, lx - 10, 0, ly - 10)
			end
			return
		end
		local a = clamp(dt * 18, 0, 1)
		self._lerpX = self._lerpX + diffX * a
		self._lerpY = self._lerpY + diffY * a
		local lx = math.floor(self._lerpX + 0.5)
		local ly = math.floor(self._lerpY + 0.5)
		main.Position         = UDim2.new(0, lx, 0, ly)
		self._shadow.Position = UDim2.new(0, lx - 10, 0, ly - 10)
		-- notifyHolder rimane fisso in basso a destra, non si muove con la finestra
	end)

	table.insert(self._conn, c1)
	table.insert(self._conn, c2)
	table.insert(self._conn, c3)
	table.insert(self._conn, c4)
end

function Library:_setupGlow()
	local g1 = self._glow1
	local g2 = self._glow2
	local time = 0
	local c = RunService.Heartbeat:Connect(function(dt)
		if self._destroyed then return end
		time = time + dt * 1.1
		local pulse = math.sin(time) * 0.035
		g1.BackgroundTransparency = clamp(0.85 + pulse, 0.80, 0.92)
		g2.BackgroundTransparency = clamp(0.88 + pulse * 0.8, 0.83, 0.94)
	end)
	table.insert(self._conn, c)
end

function Library:_startIntegrity()
	local ig = self._integrity
	local hb
	hb = RunService.Heartbeat:Connect(function()
		if self._destroyed then hb:Disconnect() return end
		if not ig.sg or not ig.sg.Parent then
			hb:Disconnect()
			self:_selfDestruct("root removed")
			return
		end
		if ig.sg.Name ~= ig.sgId then
			hb:Disconnect()
			self:_selfDestruct("root tampered")
			return
		end
		if not ig.main or not ig.main.Parent then
			hb:Disconnect()
			self:_selfDestruct("main frame removed")
			return
		end
		if ig.main.Name ~= ig.mainId then
			hb:Disconnect()
			self:_selfDestruct("main frame tampered")
			return
		end
	end)
	table.insert(self._conn, hb)
end

function Library:_selfDestruct(reason)
	if self._destroyed then return end
	self._destroyed = true
	pcall(function() if self._sg then self._sg:Destroy() end end)
	for _, c in ipairs(self._conn) do pcall(function() c:Disconnect() end) end
	table.clear(self._tabs)
	table.clear(self._conn)
	warn("[KyUI] Integrity: " .. tostring(reason))
end

