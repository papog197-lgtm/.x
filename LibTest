function TabMethods:Dropdown(text, options, default, callback)
	local t       = self._lib._t
	local sg      = self._lib._sg
	local row     = self:_row(36)
	local chosen  = default or (options and options[1]) or ""
	local panRef  = nil
	local panOpen = false

	new("TextLabel", {
		Size                   = UDim2.new(0.45, 0, 1, 0),
		Position               = UDim2.new(0, 12, 0, 0),
		BackgroundTransparency = 1,
		Font                   = Enum.Font.Gotham,
		Text                   = text or "Dropdown",
		TextColor3             = t.Text,
		TextSize               = 13,
		TextXAlignment         = Enum.TextXAlignment.Left,
		Name                   = genId(5),
		Parent                 = row,
	})
	local dropBtn = new("TextButton", {
		Size             = UDim2.new(0, 142, 0, 26),
		Position         = UDim2.new(1, -150, 0.5, -13),
		BackgroundColor3 = t.BgTer,
		BorderSizePixel  = 0,
		Font             = Enum.Font.Gotham,
		Text             = chosen .. "  ▾",
		TextColor3       = t.TextSub,
		TextSize         = 12,
		Name             = genId(6),
		Parent           = row,
	})
	new("UICorner", { CornerRadius = UDim.new(0, 6), Parent = dropBtn })
	new("UIStroke", { Color = t.Border, Thickness = 1, Transparency = 0.4, Parent = dropBtn })

	local function closePanel()
		panOpen = false
		if panRef then
			local ref = panRef
			panRef = nil
			tw(ref, { BackgroundTransparency = 1, Size = UDim2.new(0, ref.AbsoluteSize.X, 0, 0) }, 0.15).Completed:Connect(function()
				pcall(function() ref:Destroy() end)
			end)
		end
	end

	local function openPanel()
		if not options or #options == 0 then return end
		panOpen = true
		local itemH = 28
		local panW  = 142
		local panH  = math.min(#options * itemH + 8, 200)
		local absPos = dropBtn.AbsolutePosition
		local absSz  = dropBtn.AbsoluteSize
		local screen = vp()
		local px = absPos.X + absSz.X - panW
		local py = absPos.Y + absSz.Y + 4
		if py + panH > screen.Y - 10 then py = absPos.Y - panH - 4 end
		if px < 4 then px = 4 end

		local panel = new("Frame", {
			Name                   = genId(6),
			Size                   = UDim2.new(0, panW, 0, 0),
			Position               = UDim2.new(0, px, 0, py),
			BackgroundColor3       = t.PickerBg,
			BackgroundTransparency = 1,
			BorderSizePixel        = 0,
			ClipsDescendants       = true,
			ZIndex                 = 100,
			Parent                 = sg,
		})
		new("UICorner", { CornerRadius = UDim.new(0, 8), Parent = panel })
		new("UIStroke",  { Color = t.Accent, Thickness = 1, Transparency = 0.4, Parent = panel })

		local scroll = new("ScrollingFrame", {
			Size                   = UDim2.new(1, 0, 1, 0),
			BackgroundTransparency = 1,
			BorderSizePixel        = 0,
			ScrollBarThickness     = 3,
			ScrollBarImageColor3   = t.Scrollbar,
			CanvasSize             = UDim2.new(0, 0, 0, #options * itemH + 8),
			ZIndex                 = 101,
			Parent                 = panel,
		})
		new("UIListLayout", { SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0, 2), Parent = scroll })
		new("UIPadding",    {
			PaddingTop   = UDim.new(0, 4),
			PaddingLeft  = UDim.new(0, 4),
			PaddingRight = UDim.new(0, 4),
			Parent       = scroll,
		})

		for i, opt in ipairs(options) do
			local isChosen = chosen == opt
			local optBtn = new("TextButton", {
				Size                   = UDim2.new(1, 0, 0, itemH - 2),
				BackgroundColor3       = isChosen and t.AccentDark or t.BgSec,
				BackgroundTransparency = isChosen and 0 or 0.35,
				BorderSizePixel        = 0,
				Font                   = Enum.Font.Gotham,
				Text                   = opt,
				TextColor3             = isChosen and t.Text or t.TextSub,
				TextSize               = 12,
				LayoutOrder            = i,
				ZIndex                 = 102,
				Name                   = genId(5),
				Parent                 = scroll,
			})
			new("UICorner", { CornerRadius = UDim.new(0, 6), Parent = optBtn })
			optBtn.MouseEnter:Connect(function()
				if chosen ~= opt then
					tw(optBtn, { BackgroundTransparency = 0, BackgroundColor3 = t.TabHover, TextColor3 = t.Text }, 0.08)
				end
			end)
			optBtn.MouseLeave:Connect(function()
				if chosen ~= opt then
					tw(optBtn, { BackgroundTransparency = 0.35, BackgroundColor3 = t.BgSec, TextColor3 = t.TextSub }, 0.08)
				end
			end)
			optBtn.MouseButton1Click:Connect(function()
				if self._lib._locked or self._lib._destroyed then return end
				chosen = opt
				dropBtn.Text = opt .. "  ▾"
				closePanel()
				if callback then
					local s, e = pcall(callback, opt)
					if not s then warn("[KyUI] Dropdown: " .. tostring(e)) end
				end
			end)
		end

		panRef = panel
		tw(panel, { BackgroundTransparency = 0, Size = UDim2.new(0, panW, 0, panH) }, 0.18, Enum.EasingStyle.Back)
	end

	dropBtn.MouseButton1Click:Connect(function()
		if self._lib._locked or self._lib._destroyed then return end
		if panOpen then closePanel() else openPanel() end
	end)
	dropBtn.MouseEnter:Connect(function() tw(dropBtn, { BackgroundColor3 = t.TabHover }, 0.10) end)
	dropBtn.MouseLeave:Connect(function() tw(dropBtn, { BackgroundColor3 = t.BgTer }, 0.10) end)

	return {
		GetValue = function() return chosen end,
		Close    = function() closePanel() end,
	}
end

function TabMethods:ColorPicker(text, default, callback)
	local t      = self._lib._t
	local sg     = self._lib._sg
	local row    = self:_row(36)
	local color  = default or t.Accent
	local h, s, v = Color3.toHSV(color)
	local picRef  = nil
	local picOpen = false
	local svDrag, hueDrag = false, false
	local svC1, svC2, hueC1, hueC2

	new("TextLabel", {
		Size                   = UDim2.new(0.6, 0, 1, 0),
		Position               = UDim2.new(0, 12, 0, 0),
		BackgroundTransparency = 1,
		Font                   = Enum.Font.Gotham,
		Text                   = text or "Color",
		TextColor3             = t.Text,
		TextSize               = 13,
		TextXAlignment         = Enum.TextXAlignment.Left,
		Name                   = genId(5),
		Parent                 = row,
	})
	local swatch = new("TextButton", {
		Size             = UDim2.new(0, 34, 0, 22),
		Position         = UDim2.new(1, -44, 0.5, -11),
		BackgroundColor3 = color,
		BorderSizePixel  = 0,
		Text             = "",
		Name             = genId(5),
		Parent           = row,
	})
	new("UICorner", { CornerRadius = UDim.new(0, 6), Parent = swatch })
	new("UIStroke", { Color = t.Border, Thickness = 1, Transparency = 0.3, Parent = swatch })

	local function disconnectPicker()
		if svC1  then pcall(function() svC1:Disconnect()  end) svC1  = nil end
		if svC2  then pcall(function() svC2:Disconnect()  end) svC2  = nil end
		if hueC1 then pcall(function() hueC1:Disconnect() end) hueC1 = nil end
		if hueC2 then pcall(function() hueC2:Disconnect() end) hueC2 = nil end
		svDrag, hueDrag = false, false
	end

	local function closePicker()
		picOpen = false
		disconnectPicker()
		if picRef then
			local ref = picRef
			picRef = nil
			tw(ref, { BackgroundTransparency = 1 }, 0.18).Completed:Connect(function()
				pcall(function() ref:Destroy() end)
			end)
		end
	end

	local function buildPicker()
		local absPos = swatch.AbsolutePosition
		local absSz  = swatch.AbsoluteSize
		local screen = vp()
		local picW, picH = 214, 240
		local px = absPos.X + absSz.X - picW
		local py = absPos.Y + absSz.Y + 6
		if py + picH > screen.Y - 10 then py = absPos.Y - picH - 6 end
		if px < 6 then px = 6 end

		local pf = new("Frame", {
			Name                   = genId(6),
			Size                   = UDim2.new(0, picW, 0, picH),
			Position               = UDim2.new(0, px, 0, py),
			BackgroundColor3       = t.PickerBg,
			BackgroundTransparency = 1,
			BorderSizePixel        = 0,
			ZIndex                 = 100,
			ClipsDescendants       = false,
			Parent                 = sg,
		})
		new("UICorner", { CornerRadius = UDim.new(0, 10), Parent = pf })
		new("UIStroke",  { Color = t.Accent, Thickness = 1, Transparency = 0.4, Parent = pf })

		local pad  = 10
		local svW  = picW - pad * 2
		local svH  = 130

		local svFrame = new("Frame", {
			Name             = genId(5),
			Size             = UDim2.new(0, svW, 0, svH),
			Position         = UDim2.new(0, pad, 0, pad),
			BackgroundColor3 = Color3.fromHSV(h, 1, 1),
			BorderSizePixel  = 0,
			ZIndex           = 101,
			ClipsDescendants = true,
			Parent           = pf,
		})
		new("UICorner", { CornerRadius = UDim.new(0, 6), Parent = svFrame })

		local wLayer = new("Frame", {
			Size                   = UDim2.new(1, 0, 1, 0),
			BackgroundColor3       = Color3.new(1, 1, 1),
			BackgroundTransparency = 0,
			BorderSizePixel        = 0,
			ZIndex                 = 102,
			Parent                 = svFrame,
		})
		new("UIGradient", {
			Transparency = NumberSequence.new({
				NumberSequenceKeypoint.new(0, 0),
				NumberSequenceKeypoint.new(1, 1),
			}),
			Parent = wLayer,
		})

		local bLayer = new("Frame", {
			Size                   = UDim2.new(1, 0, 1, 0),
			BackgroundColor3       = Color3.new(0, 0, 0),
			BackgroundTransparency = 0,
			BorderSizePixel        = 0,
			ZIndex                 = 103,
			Parent                 = svFrame,
		})
		new("UIGradient", {
			Transparency = NumberSequence.new({
				NumberSequenceKeypoint.new(0, 1),
				NumberSequenceKeypoint.new(1, 0),
			}),
			Rotation = 90,
			Parent   = bLayer,
		})

		local svCursor = new("Frame", {
			Name             = genId(4),
			Size             = UDim2.new(0, 12, 0, 12),
			Position         = UDim2.new(s, -6, 1 - v, -6),
			BackgroundColor3 = Color3.new(1, 1, 1),
			BorderSizePixel  = 0,
			ZIndex           = 106,
			Parent           = svFrame,
		})
		new("UICorner", { CornerRadius = UDim.new(1, 0), Parent = svCursor })
		new("UIStroke",  { Color = Color3.new(0, 0, 0), Thickness = 1.5, Parent = svCursor })

		local svHit = new("TextButton", {
			Size                   = UDim2.new(1, 0, 1, 0),
			BackgroundTransparency = 1,
			Text                   = "",
			ZIndex                 = 107,
			Parent                 = svFrame,
		})

		local hueY  = pad + svH + 8
		local hueBar = new("Frame", {
			Name             = genId(5),
			Size             = UDim2.new(0, svW, 0, 14),
			Position         = UDim2.new(0, pad, 0, hueY),
			BackgroundColor3 = Color3.new(1, 1, 1),
			BorderSizePixel  = 0,
			ZIndex           = 101,
			Parent           = pf,
		})
		new("UICorner", { CornerRadius = UDim.new(0, 4), Parent = hueBar })
		new("UIGradient", {
			Color = ColorSequence.new({
				ColorSequenceKeypoint.new(0,    Color3.fromHSV(0,    1, 1)),
				ColorSequenceKeypoint.new(0.17, Color3.fromHSV(0.17, 1, 1)),
				ColorSequenceKeypoint.new(0.33, Color3.fromHSV(0.33, 1, 1)),
				ColorSequenceKeypoint.new(0.50, Color3.fromHSV(0.50, 1, 1)),
				ColorSequenceKeypoint.new(0.67, Color3.fromHSV(0.67, 1, 1)),
				ColorSequenceKeypoint.new(0.83, Color3.fromHSV(0.83, 1, 1)),
				ColorSequenceKeypoint.new(1,    Color3.fromHSV(1,    1, 1)),
			}),
			Parent = hueBar,
		})

		local hueCursor = new("Frame", {
			Name             = genId(4),
			Size             = UDim2.new(0, 4, 1, 6),
			Position         = UDim2.new(h, -2, 0, -3),
			BackgroundColor3 = Color3.new(1, 1, 1),
			BorderSizePixel  = 0,
			ZIndex           = 102,
			Parent           = hueBar,
		})
		new("UICorner", { CornerRadius = UDim.new(0, 2), Parent = hueCursor })
		new("UIStroke",  { Color = Color3.new(0, 0, 0), Thickness = 1, Parent = hueCursor })

		local hueHit = new("TextButton", {
			Size                   = UDim2.new(1, 0, 1, 8),
			Position               = UDim2.new(0, 0, 0, -4),
			BackgroundTransparency = 1,
			Text                   = "",
			ZIndex                 = 103,
			Parent                 = hueBar,
		})

		local prevY = hueY + 14 + 8
		local preview = new("Frame", {
			Name             = genId(5),
			Size             = UDim2.new(0, svW, 0, 26),
			Position         = UDim2.new(0, pad, 0, prevY),
			BackgroundColor3 = color,
			BorderSizePixel  = 0,
			ZIndex           = 101,
			Parent           = pf,
		})
		new("UICorner", { CornerRadius = UDim.new(0, 6), Parent = preview })
		new("UIStroke",  { Color = t.Border, Thickness = 1, Transparency = 0.4, Parent = preview })

		local applyY  = prevY + 34
		local applyBtn = new("TextButton", {
			Name             = genId(5),
			Size             = UDim2.new(0, svW, 0, 28),
			Position         = UDim2.new(0, pad, 0, applyY),
			BackgroundColor3 = t.Accent,
			BorderSizePixel  = 0,
			Font             = Enum.Font.GothamBold,
			Text             = "Apply",
			TextColor3       = Color3.new(1, 1, 1),
			TextSize         = 13,
			ZIndex           = 101,
			Parent           = pf,
		})
		new("UICorner", { CornerRadius = UDim.new(0, 6), Parent = applyBtn })

		local function refreshPreview()
			local c = Color3.fromHSV(h, s, v)
			preview.BackgroundColor3 = c
		end

		local function doSV(ix, iy)
			local ap = svFrame.AbsolutePosition
			local as = svFrame.AbsoluteSize
			s = clamp((ix - ap.X) / as.X, 0, 1)
			v = clamp(1 - ((iy - ap.Y) / as.Y), 0, 1)
			svCursor.Position = UDim2.new(s, -6, 1 - v, -6)
			refreshPreview()
		end

		local function doHue(ix)
			local ap = hueBar.AbsolutePosition
			local as = hueBar.AbsoluteSize
			h = clamp((ix - ap.X) / as.X, 0, 1)
			hueCursor.Position             = UDim2.new(h, -2, 0, -3)
			svFrame.BackgroundColor3       = Color3.fromHSV(h, 1, 1)
			refreshPreview()
		end

		svHit.MouseButton1Down:Connect(function(x, y)
			svDrag = true
			doSV(x, y)
		end)
		svC1 = UserInputService.InputChanged:Connect(function(inp)
			if svDrag and inp.UserInputType == Enum.UserInputType.MouseMovement then
				doSV(inp.Position.X, inp.Position.Y)
			end
		end)
		svC2 = UserInputService.InputEnded:Connect(function(inp)
			if inp.UserInputType == Enum.UserInputType.MouseButton1 then svDrag = false end
		end)

		hueHit.MouseButton1Down:Connect(function(x)
			hueDrag = true
			doHue(x)
		end)
		hueC1 = UserInputService.InputChanged:Connect(function(inp)
			if hueDrag and inp.UserInputType == Enum.UserInputType.MouseMovement then
				doHue(inp.Position.X)
			end
		end)
		hueC2 = UserInputService.InputEnded:Connect(function(inp)
			if inp.UserInputType == Enum.UserInputType.MouseButton1 then hueDrag = false end
		end)

		applyBtn.MouseButton1Click:Connect(function()
			if self._lib._locked or self._lib._destroyed then return end
			color = Color3.fromHSV(h, s, v)
			swatch.BackgroundColor3 = color
			if callback then
				local ok2, e = pcall(callback, color)
				if not ok2 then warn("[KyUI] ColorPicker: " .. tostring(e)) end
			end
			closePicker()
		end)
		applyBtn.MouseEnter:Connect(function() tw(applyBtn, { BackgroundColor3 = t.AccentGlow }, 0.10) end)
		applyBtn.MouseLeave:Connect(function() tw(applyBtn, { BackgroundColor3 = t.Accent }, 0.10) end)

		tw(pf, { BackgroundTransparency = 0 }, 0.18)
		return pf
	end

	swatch.MouseButton1Click:Connect(function()
		if self._lib._locked or self._lib._destroyed then return end
		if picOpen then closePicker()
		else picOpen = true; picRef = buildPicker() end
	end)

	return {
		GetValue = function() return color end,
		SetValue = function(_, c)
			color = c
			swatch.BackgroundColor3 = c
			h, s, v = Color3.toHSV(c)
		end,
	}
end

