function Library:_animIn()
	local m = self._main
	local s = self._shadow
	m.BackgroundTransparency = 1
	m.Position = UDim2.new(0.5, -251, 0.5, -166)
	s.BackgroundTransparency = 1
	tw(m, { BackgroundTransparency = self._alpha, Position = UDim2.new(0.5, -251, 0.5, -186) }, 0.45, Enum.EasingStyle.Back)
	tw(s, { BackgroundTransparency = 0.82 }, 0.5)
end

function Library:_setupDrag()
	local main   = self._main
	local topBar = self._topBar
	local dragging, dragStart, startPos = false, nil, nil

	local c1 = topBar.InputBegan:Connect(function(inp)
		if inp.UserInputType == Enum.UserInputType.MouseButton1 or
		   inp.UserInputType == Enum.UserInputType.Touch then
			dragging  = true
			dragStart = inp.Position
			startPos  = main.Position
		end
	end)
	local c2 = UserInputService.InputChanged:Connect(function(inp)
		if not dragging then return end
		if inp.UserInputType ~= Enum.UserInputType.MouseMovement and
		   inp.UserInputType ~= Enum.UserInputType.Touch then return end
		local delta = inp.Position - dragStart
		local nx = startPos.X.Offset + delta.X
		local ny = startPos.Y.Offset + delta.Y
		main.Position = UDim2.new(startPos.X.Scale, nx, startPos.Y.Scale, ny)
		self._shadow.Position = UDim2.new(startPos.X.Scale, nx - 5, startPos.Y.Scale, ny - 5)
	end)
	local c3 = UserInputService.InputEnded:Connect(function(inp)
		if inp.UserInputType == Enum.UserInputType.MouseButton1 or
		   inp.UserInputType == Enum.UserInputType.Touch then
			dragging = false
		end
	end)
	table.insert(self._conn, c1)
	table.insert(self._conn, c2)
	table.insert(self._conn, c3)
end

function Library:_toggleMinimize()
	self._minimized = not self._minimized
	if self._minimized then
		tw(self._main,   { Size = UDim2.new(0, 502, 0, 47) }, 0.3)
		tw(self._shadow, { Size = UDim2.new(0, 512, 0, 57) }, 0.3)
		self._minBtn.Text = "□"
	else
		tw(self._main,   { Size = UDim2.new(0, 502, 0, 372) }, 0.3, Enum.EasingStyle.Back)
		tw(self._shadow, { Size = UDim2.new(0, 512, 0, 382) }, 0.3, Enum.EasingStyle.Back)
		self._minBtn.Text = "—"
	end
end

function Library:_startIntegrity()
	local ig = self._integrity
	local hb
	hb = RunService.Heartbeat:Connect(function()
		if self._destroyed then hb:Disconnect() return end
		if not ig.sg or not ig.sg.Parent then
			hb:Disconnect()
			self:_selfDestruct("root removed")
			return
		end
		if ig.sg.Name ~= ig.sgName then
			hb:Disconnect()
			self:_selfDestruct("root name tampered")
			return
		end
		if not ig.main or not ig.main.Parent then
			hb:Disconnect()
			self:_selfDestruct("main frame removed")
			return
		end
		if ig.main.Name ~= ig.mainName then
			hb:Disconnect()
			self:_selfDestruct("main frame name tampered")
			return
		end
	end)
	table.insert(self._conn, hb)
end

function Library:_selfDestruct(reason)
	if self._destroyed then return end
	self._destroyed = true
	pcall(function() if self._sg then self._sg:Destroy() end end)
	for _, c in ipairs(self._conn) do pcall(function() c:Disconnect() end) end
	table.clear(self._tabs)
	table.clear(self._conn)
	warn("[PhantomUI] Security: " .. tostring(reason))
end

