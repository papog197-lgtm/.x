			tw(track, { BackgroundColor3 = state and t.ToggleOn or t.ToggleOff }, 0.2)
			tw(knob,  { Position = state and UDim2.new(1, -19, 0.5, -8) or UDim2.new(0, 3, 0.5, -8) }, 0.2)
		end,
		GetValue = function() return state end,
	}
end

function TabMethods:Slider(text, min, max, default, callback)
	local t    = self._lib._t
	local row  = self:_row(52)
	local val  = math.clamp(default or min, min, max)
	new("TextLabel", {
		Size                  = UDim2.new(0.6, 0, 0, 22),
		Position              = UDim2.new(0, 12, 0, 4),
		BackgroundTransparency = 1,
		Font                  = Enum.Font.Gotham,
		Text                  = text or "Slider",
		TextColor3            = t.Text,
		TextSize              = 13,
		TextXAlignment        = Enum.TextXAlignment.Left,
		Name                  = genId(5),
		Parent                = row,
	})
	local valLabel = new("TextLabel", {
		Size                  = UDim2.new(0.35, 0, 0, 22),
		Position              = UDim2.new(0.64, 0, 0, 4),
		BackgroundTransparency = 1,
		Font                  = Enum.Font.GothamBold,
		Text                  = tostring(math.floor(val)),
		TextColor3            = t.Accent,
		TextSize              = 13,
		TextXAlignment        = Enum.TextXAlignment.Right,
		Name                  = genId(5),
		Parent                = row,
	})
	local track = new("Frame", {
		Size             = UDim2.new(1, -24, 0, 6),
		Position         = UDim2.new(0, 12, 0, 32),
		BackgroundColor3 = t.SliderBg,
		BorderSizePixel  = 0,
		Name             = genId(5),
		Parent           = row,
	})
	new("UICorner", { CornerRadius = UDim.new(1, 0), Parent = track })
	local fillPct = (val - min) / (max - min)
	local fill = new("Frame", {
		Size             = UDim2.new(fillPct, 0, 1, 0),
		BackgroundColor3 = t.SliderFill,
		BorderSizePixel  = 0,
		Name             = genId(5),
		Parent           = track,
	})
	new("UICorner", { CornerRadius = UDim.new(1, 0), Parent = fill })
	new("UIGradient", {
		Color = ColorSequence.new({
			ColorSequenceKeypoint.new(0, t.AccentGlow),
			ColorSequenceKeypoint.new(1, t.Accent),
		}),
		Parent = fill,
	})
	local thumb = new("Frame", {
		Size             = UDim2.new(0, 14, 0, 14),
		Position         = UDim2.new(fillPct, -7, 0.5, -7),
		BackgroundColor3 = Color3.fromRGB(255, 255, 255),
		BorderSizePixel  = 0,
		ZIndex           = 3,
		Name             = genId(5),
		Parent           = track,
	})
	new("UICorner",  { CornerRadius = UDim.new(1, 0), Parent = thumb })
	new("UIStroke",  { Color = t.Accent, Thickness = 2, Parent = thumb })
	local dragging = false
	local hitbox = new("TextButton", {
		Size                  = UDim2.new(1, 0, 0, 30),
		Position              = UDim2.new(0, 0, 0, -12),
		BackgroundTransparency = 1,
		Text                  = "",
		ZIndex                = 4,
		Name                  = genId(5),
		Parent                = track,
	})
	local function updateSlider(inputX)
		local absX  = track.AbsolutePosition.X
		local absW  = track.AbsoluteSize.X
		local pct   = math.clamp((inputX - absX) / absW, 0, 1)
		local newVal = math.floor(min + (max - min) * pct)
		val = newVal
		valLabel.Text = tostring(newVal)
		tw(fill,  { Size = UDim2.new(pct, 0, 1, 0) }, 0.05)
		tw(thumb, { Position = UDim2.new(pct, -7, 0.5, -7) }, 0.05)
		if callback then
			local s, e = pcall(callback, newVal)
			if not s then warn("[PhantomUI] Slider error: " .. tostring(e)) end
		end
	end
	hitbox.MouseButton1Down:Connect(function(x, _)
		if self._lib._locked or self._lib._destroyed then return end
		dragging = true
		updateSlider(x)
	end)
	local moveConn = UserInputService.InputChanged:Connect(function(inp)
		if dragging and inp.UserInputType == Enum.UserInputType.MouseMovement then
			updateSlider(inp.Position.X)
		end
	end)
	local upConn = UserInputService.InputEnded:Connect(function(inp)
		if inp.UserInputType == Enum.UserInputType.MouseButton1 then
			dragging = false
		end
	end)
	table.insert(self._lib._conn, moveConn)
	table.insert(self._lib._conn, upConn)
	return {
		SetValue = function(_, v)
			val = math.clamp(v, min, max)
			local pct = (val - min) / (max - min)
			valLabel.Text = tostring(math.floor(val))
			tw(fill,  { Size = UDim2.new(pct, 0, 1, 0) }, 0.1)
			tw(thumb, { Position = UDim2.new(pct, -7, 0.5, -7) }, 0.1)
		end,
		GetValue = function() return val end,
	}
end

