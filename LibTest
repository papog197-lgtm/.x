function Library:Init(cfg)
	if not cfg then return nil end
	if type(cfg.Key) ~= "string" or #cfg.Key < 6 then return nil end

	local self      = setmetatable({}, Library)
	self._id        = genId(16)
	self._frameId   = genId(10)
	self._cfg       = cfg
	self._tabs      = {}
	self._tabOrder  = {}
	self._activeTab = nil
	self._conn      = {}
	self._locked    = false
	self._destroyed = false

	local t = {}
	for k, v in pairs(THEME) do t[k] = v end
	if cfg.AccentColor then
		t.Accent     = cfg.AccentColor
		t.AccentGlow = cfg.AccentColor
		t.ToggleOn   = cfg.AccentColor
		t.SliderFill = cfg.AccentColor
		t.TabActive  = cfg.AccentColor
	end
	if cfg.BackgroundColor then t.Bg = cfg.BackgroundColor end
	if cfg.TextColor       then t.Text = cfg.TextColor end
	self._t           = t
	self._alpha       = math.clamp(cfg.Transparency or 0.05, 0, 0.5)
	self._title       = cfg.Title    or "PhantomUI"
	self._subtitle    = cfg.Subtitle or ""
	self._minimized   = false

	self:_buildGUI()
	self:_setupDrag()
	self:_startIntegrity()
	self:_animIn()

	return self
end

