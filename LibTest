function TabMethods:Dropdown(text, options, default, callback)
	local t=self._lib._t; local sg=self._lib._sg
	local row=self:_row(36)
	local chosen=default or (options and options[1]) or ""
	local panRef,panOpen=nil,false
	new("TextLabel", { Size=UDim2.new(0.45,0,1,0), Position=UDim2.new(0,12,0,0), BackgroundTransparency=1, Font=Enum.Font.Gotham, Text=text or "Dropdown", TextColor3=t.Text, TextSize=13, TextXAlignment=Enum.TextXAlignment.Left, Name=genId(5), Parent=row })
	local dropBtn=new("TextButton", { Size=UDim2.new(0,142,0,26), Position=UDim2.new(1,-150,0.5,-13), BackgroundColor3=t.BgTer, BorderSizePixel=0, Font=Enum.Font.Gotham, Text=chosen.."  ▾", TextColor3=t.TextSub, TextSize=12, Name=genId(6), Parent=row })
	new("UICorner", { CornerRadius=UDim.new(0,6), Parent=dropBtn })
	new("UIStroke", { Color=t.Border, Thickness=1, Transparency=0.4, Parent=dropBtn })
	local function closePanel()
		panOpen=false
		if panRef then local ref=panRef; panRef=nil; tw(ref,{BackgroundTransparency=1,Size=UDim2.new(0,ref.AbsoluteSize.X,0,0)},0.15).Completed:Connect(function() pcall(function() ref:Destroy() end) end) end
	end
	local function openPanel()
		if not options or #options==0 then return end
		panOpen=true
		local itemH,panW=28,142
		local panH=math.min(#options*itemH+8,200)
		local absPos=dropBtn.AbsolutePosition; local absSz=dropBtn.AbsoluteSize; local screen=vp()
		local px=absPos.X+absSz.X-panW; local py=absPos.Y+absSz.Y+4
		if py+panH>screen.Y-10 then py=absPos.Y-panH-4 end
		if px<4 then px=4 end
		local panel=new("Frame",{Name=genId(6),Size=UDim2.new(0,panW,0,0),Position=UDim2.new(0,px,0,py),BackgroundColor3=t.PickerBg,BackgroundTransparency=1,BorderSizePixel=0,ClipsDescendants=true,ZIndex=100,Parent=sg})
		new("UICorner",{CornerRadius=UDim.new(0,8),Parent=panel}); new("UIStroke",{Color=t.Accent,Thickness=1,Transparency=0.4,Parent=panel})
		local scroll=new("ScrollingFrame",{Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,BorderSizePixel=0,ScrollBarThickness=3,ScrollBarImageColor3=t.Scrollbar,CanvasSize=UDim2.new(0,0,0,#options*itemH+8),ZIndex=101,Parent=panel})
		new("UIListLayout",{SortOrder=Enum.SortOrder.LayoutOrder,Padding=UDim.new(0,2),Parent=scroll})
		new("UIPadding",{PaddingTop=UDim.new(0,4),PaddingLeft=UDim.new(0,4),PaddingRight=UDim.new(0,4),Parent=scroll})
		for i,opt in ipairs(options) do
			local isChosen=chosen==opt
			local optBtn=new("TextButton",{Size=UDim2.new(1,0,0,itemH-2),BackgroundColor3=isChosen and t.AccentDark or t.BgSec,BackgroundTransparency=isChosen and 0 or 0.35,BorderSizePixel=0,Font=Enum.Font.Gotham,Text=opt,TextColor3=isChosen and t.Text or t.TextSub,TextSize=12,LayoutOrder=i,ZIndex=102,Name=genId(5),Parent=scroll})
			new("UICorner",{CornerRadius=UDim.new(0,6),Parent=optBtn})
			optBtn.MouseEnter:Connect(function() if chosen~=opt then tw(optBtn,{BackgroundTransparency=0,BackgroundColor3=t.TabHover,TextColor3=t.Text},0.08) end end)
			optBtn.MouseLeave:Connect(function() if chosen~=opt then tw(optBtn,{BackgroundTransparency=0.35,BackgroundColor3=t.BgSec,TextColor3=t.TextSub},0.08) end end)
			optBtn.MouseButton1Click:Connect(function()
				if self._lib._locked or self._lib._destroyed then return end
				chosen=opt; dropBtn.Text=opt.."  ▾"; closePanel()
				if callback then local s,e=pcall(callback,opt); if not s then warn("[KyUI] Dropdown: "..tostring(e)) end end
			end)
		end
		panRef=panel; tw(panel,{BackgroundTransparency=0,Size=UDim2.new(0,panW,0,panH)},0.18,Enum.EasingStyle.Back)
	end
	dropBtn.MouseButton1Click:Connect(function() if self._lib._locked or self._lib._destroyed then return end if panOpen then closePanel() else openPanel() end end)
	dropBtn.MouseEnter:Connect(function() tw(dropBtn,{BackgroundColor3=t.TabHover},0.10) end)
	dropBtn.MouseLeave:Connect(function() tw(dropBtn,{BackgroundColor3=t.BgTer},0.10) end)
	return { GetValue=function() return chosen end, Close=function() closePanel() end }
end

